# Copy to .env.local and fill in real values.

# Neon Postgres (dev branch). Use the pooled connection string with sslmode=require.
DATABASE_URL=postgres://USER:PASSWORD@HOST/db?sslmode=require

# Auth.js v5. Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Seed user (consumed by scripts/seed.ts)
SEED_PLANNER_EMAIL=
SEED_PLANNER_PASSWORD=

# OpenAI (Vercel AI SDK planner)
OPENAI_API_KEY=
OPENAI_PLANNER_MODEL=gpt-4o
